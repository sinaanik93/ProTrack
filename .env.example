APP_ENV=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
DATABASE_URL=json://data/protrack_ai_db.json
STORAGE_PROVIDER=local
PROTRACK_STORAGE_ROOT=data/storage
JWT_SECRET=change-me-before-production
PROTRACK_REVIEW_MODE=manual
PROTRACK_MAX_VIDEO_BYTES=2000000000
PROTRACK_MAX_KEYFRAMES=12
PROTRACK_OPENAI_TIMEOUT_SECONDS=90
PROTRACK_VIDEO_FORMATS=.mp4,.mov,.m4v,.webm
PROTRACK_PORT=4173
